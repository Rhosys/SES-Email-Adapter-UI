{
  "name": "ses-email-adapter-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue --max-warnings 0",
    "format:check": "prettier --check .",
    "check": "vue-tsc --noEmit && vite build && eslint . --ext .ts,.vue --max-warnings 0 && prettier --check . && vitest run",
    "deploy:website": "tsx scripts/deploy-website.ts"
  },
  "dependencies": {
    "@authress/login": "^2.4.0",
    "@catppuccin/palette": "^1.7.1",
    "marked": "^18.0.3",
    "neverthrow": "^8.2.0",
    "pinia": "^2.2.4",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/vite": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^2.1.4",
    "@vue/test-utils": "^2.4.6",
    "aws-architect": "^6.7.158",
    "aws-sdk": "^2.1693.0",
    "glob": "^7.2.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.48.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.4",
    "vue-tsc": "^2.1.10"
  }
}
