{
  "name": "ses-email-adapter-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "landing": "serve landing -l 8080",
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:pwa": "playwright test --project=pwa",
    "coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue --max-warnings 0",
    "lint:ci": "eslint . --ext .ts,.vue",
    "format:check": "prettier --check .",
    "check": "vue-tsc --noEmit && npm run lint && vitest run",
    "check:ci": "vue-tsc --noEmit && npm run lint:ci && vitest run",
    "deploy:website": "tsx scripts/deploy-website.ts",
    "deploy:landing": "tsx scripts/deploy-landing.ts"
  },
  "dependencies": {
    "@authress/login": "^2.4.0",
    "@catppuccin/palette": "^1.7.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "codemirror": "^6.0.2",
    "echarts": "^6.1.0",
    "handlebars": "^4.7.9",
    "marked": "^18.0.3",
    "neverthrow": "^8.2.0",
    "pinia": "^2.2.4",
    "posthog-js": "^1.373.5",
    "textarea-caret": "^3.1.0",
    "vue": "^3.5.13",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/textarea-caret": "^3.0.4",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^2.1.4",
    "@vue/test-utils": "^2.4.6",
    "aws-architect": "^6.7.163",
    "aws-sdk": "^2.1693.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "glob": "^7.2.3",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "msw": "^2.14.6",
    "playwright": "^1.48.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.4",
    "vitest-axe": "^0.1.0",
    "vue-tsc": "^2.1.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
